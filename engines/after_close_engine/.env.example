# After Close Engine Configuration

# Core settings
AFTER_CLOSE_ENABLED=true
CONFIDENCE_THRESHOLD=0.70
SYMBOL=AMD

# Paths
PREDICTION_PATH=/data/predictions/after_close
LOG_PATH=/logs/after_close
SNAPSHOT_PATH=/data/engine_snapshot/latest.json

# Development settings
AUTO_FIT_ON_DEV=false
DEBUG_MODE=false
MOCK_MODE=true
TIMEZONE=US/Eastern

# API server settings (optional)
SERVE_PORT=5001
SERVE_HOST=0.0.0.0

# Production API keys (TODO: Add real keys)
# FUTURES_API_KEY=your_futures_api_key
# OPTIONS_API_KEY=your_options_api_key  
# NEWS_API_KEY=your_news_api_key
# GLOBAL_INDICES_API_KEY=your_global_api_key