# AMD Stock Prediction System - Environment Variables Template
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control!

# ====== ESSENTIAL API KEYS ======

# Data Sources (at least one recommended)
POLYGON_API_KEY=your_polygon_api_key_here
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here
EODHD_API_KEY=your_eodhd_api_key_here
FINNHUB_API_KEY=your_finnhub_api_key_here

# ====== SMS NOTIFICATIONS (Twilio) ======
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890
SMS_ALERT_PHONE=+1234567890

# ====== DATABASE (PostgreSQL) ======
DATABASE_URL=postgresql://user:password@localhost:5432/stock_predictions
REPLIT_DATABASE_URL=your_replit_db_url_here

# ====== OPTIONAL ADVANCED APIS ======
QUANDL_API_KEY=your_quandl_key_here
IEX_CLOUD_API_KEY=your_iex_cloud_key_here
BENZINGA_API_KEY=your_benzinga_key_here
CBOE_API_KEY=your_cboe_key_here
TD_AMERITRADE_API_KEY=your_td_key_here

# ====== REDDIT SENTIMENT (Optional) ======
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_secret_here
REDDIT_USERNAME=your_reddit_username_here
REDDIT_PASSWORD=your_reddit_password_here

# ====== TWITTER/X SENTIMENT (Optional) ======
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# ====== ECONOMIC DATA (Optional) ======
FRED_API_KEY=your_fred_api_key_here

# ====== FUTURES & OPTIONS (Optional) ======
FUTURES_API_KEY=your_futures_api_key_here
OPTIONS_API_KEY=your_options_api_key_here

# ====== SYSTEM CONFIGURATION ======
PYTHON_ENV=development
DEBUG_MODE=True
LOG_LEVEL=INFO
